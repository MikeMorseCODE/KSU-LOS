name: OnePlus 11 GKI Kernel Build + KSU-Next + SUSFS + Release

on:
  workflow_dispatch:
    inputs:
      lineage_build_url:
        description: 'Optional: LineageOS build URL (not used, kept for compat)'
        required: false
        type: string
  schedule:
    - cron: '0 4 * * *'

jobs:
  build_kernel:
    runs-on: ubuntu-latest
    env:
      ARCH: arm64
      CROSS_COMPILE: aarch64-linux-gnu-
      DEFCONFIG: lineage_oneplus11_defconfig
      CCACHE_DIR: ${{ github.workspace }}/.ccache
      KERNEL_OUT: out

    steps:
      - name: Configure git auth
        run: git config --global url."https://x-access-token:${{ secrets.GITHUB_TOKEN }}@github.com/".insteadOf "https://github.com/"

      - name: Install dependencies
        run: |
          sudo apt-get update -y
          sudo apt-get install -y git curl unzip bc flex bison libssl-dev libelf-dev \
              python3 python3-pip python3-setuptools python3-venv python3-dev \
              build-essential libncurses-dev wget zip lsb-release software-properties-common
          # Ensure distutils installs for Python 3.12+
          sudo apt-get install -y python3.12-distutils || sudo apt-get install -y python3-distutils || echo "Distutils not found, skipping"

      - name: Clone LineageOS kernel repos
        run: |
          git clone -b lineage-23.2 https://github.com/LineageOS/android_kernel_oneplus_sm8550-common.git kernel/oneplus/sm8550 || true
          git clone -b lineage-23.2 https://github.com/LineageOS/android_device_oneplus_sm8550-common.git kernel/oneplus/sm8550-devicecommon || true

      - name: Detect kernel version
        run: |
          KVER=$(grep "^VERSION =" kernel/oneplus/sm8550/Makefile | awk '{print $3}')
          echo "Kernel version: $KVER"

      - name: Patch live defconfig for GKI
        run: |
          if [ ! -f ../../lineage_oneplus11_defconfig ]; then
            echo "lineage_oneplus11_defconfig missing!"
            exit 1
          fi
          cp ../../lineage_oneplus11_defconfig arch/arm64/configs/
          echo "# CONFIG_OPLUS_SENSOR_DEVINFO is not set" >> arch/arm64/configs/lineage_oneplus11_defconfig
          echo "# CONFIG_OPLUS_FEATURE_SENSOR_CFG is not set" >> arch/arm64/configs/lineage_oneplus11_defconfig
          echo "Patched lineage_oneplus11_defconfig to disable Oplus sensors"

      - name: Setup KernelSU-Next
        run: echo "KernelSU-Next setup placeholder"

      - name: Clone SUSFS repo
        run: echo "SUSFS repo clone placeholder"

      - name: Apply SUSFS patches
        run: echo "Apply SUSFS patches placeholder"

      - name: Clone and apply WildKernels patches
        run: echo "Apply WildKernels patches placeholder"

      - name: Build kernel
        run: echo "Build kernel placeholder"

      - name: Compile modules
        run: echo "Compile modules placeholder"

      - name: Checkout repo for AnyKernel3
        run: echo "Checkout AnyKernel3 placeholder"

      - name: Package AnyKernel3 zip
        run: echo "Package AnyKernel3 placeholder"

      - name: Upload artifact
        run: echo "Upload artifact placeholder"

      - name: Create GitHub release
        run: echo "Create GitHub release placeholder"